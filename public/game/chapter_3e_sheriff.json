            "village_sheriff_misunderstanding"
          ]
        },
        {
          "text": "Duck",
          "triggers": [
            {
              "type": "add_flag",
              "target": "village_sheriff_ducked"
            }
          ],
          "showAny": [
            "village_sheriff_dodge_right"
          ],
          "hideAny": [
            "village_sheriff_close_eyes",
            "village_sheriff_take_swing",
            "village_sheriff_ducked"
          ]
        },
        {
          "text": "Take a swing",
          "triggers": [
            {
              "type": "add_flag",
              "target": "village_sheriff_take_swing"
            }
          ],
          "showAny": [
            "village_sheriff_ducked"
          ],
          "hideAny": [
            "village_sheriff_close_eyes",
            "village_sheriff_take_swing",
            "village_sheriff_misunderstanding"
          ]
        },
        {
          "text": "Say it is just a misunderstanding",
          "triggers": [
            {
              "type": "add_flag",
              "target": "village_sheriff_misunderstanding"
            }
          ],
          "showAny": [
